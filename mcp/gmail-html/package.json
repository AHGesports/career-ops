{
  "name": "gmail-html-mcp",
  "version": "1.0.0",
  "description": "Local MCP server exposing Gmail messages with full HTML body. Read-only scope. Uses Google's official googleapis SDK.",
  "type": "module",
  "main": "index.mjs",
  "bin": {
    "gmail-html-mcp": "./index.mjs"
  },
  "scripts": {
    "auth": "node auth.mjs",
    "start": "node index.mjs",
    "scan": "node scripts/scan.mjs",
    "extract": "node scripts/extract-urls.mjs",
    "follow": "node scripts/follow-trackers.mjs",
    "append": "node scripts/append-pipeline.mjs",
    "playwright:install": "npm install playwright && npx playwright install chromium"
  },
  "optionalDependencies": {
    "playwright": "^1.48.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "googleapis": "^171.4.0",
    "yaml": "^2.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
